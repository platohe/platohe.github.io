<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
  <defs>
    <linearGradient id="shieldGradient32" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Shield background -->
  <path d="M16 2 L28 8 L28 18 C28 24 22 30 16 30 C10 30 4 24 4 18 L4 8 Z" 
        fill="url(#shieldGradient32)" 
        stroke="#1e40af" 
        stroke-width="1"/>
  
  <!-- Lock body -->
  <rect x="11" y="14" width="10" height="8" rx="1" fill="#ffffff" opacity="0.9"/>
  
  <!-- Lock shackle -->
  <path d="M13 14 L13 11 C13 9 14 8 16 8 C18 8 19 9 19 11 L19 14" 
        fill="none" 
        stroke="#ffffff" 
        stroke-width="2" 
        stroke-linecap="round"
        opacity="0.9"/>
  
  <!-- Keyhole -->
  <circle cx="16" cy="17" r="1.5" fill="#3b82f6"/>
  <path d="M16 18.5 L16 20" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/>
  
  <!-- Subtle highlight -->
  <path d="M16 2 L16 30" 
        fill="none" 
        stroke="#ffffff" 
        stroke-width="0.5" 
        opacity="0.3"/>
</svg>
