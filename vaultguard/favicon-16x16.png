<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
  <defs>
    <linearGradient id="shieldGradient16" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Shield background -->
  <path d="M8 1 L14 4 L14 9 C14 12 11 15 8 15 C5 15 2 12 2 9 L2 4 Z" 
        fill="url(#shieldGradient16)" 
        stroke="#1e40af" 
        stroke-width="0.5"/>
  
  <!-- Lock body -->
  <rect x="5.5" y="7" width="5" height="4" rx="0.5" fill="#ffffff" opacity="0.9"/>
  
  <!-- Lock shackle -->
  <path d="M6.5 7 L6.5 5.5 C6.5 4.5 7 4 8 4 C9 4 9.5 4.5 9.5 5.5 L9.5 7" 
        fill="none" 
        stroke="#ffffff" 
        stroke-width="1" 
        stroke-linecap="round"
        opacity="0.9"/>
  
  <!-- Keyhole -->
  <circle cx="8" cy="8.5" r="0.75" fill="#3b82f6"/>
  <path d="M8 9.25 L8 10" stroke="#3b82f6" stroke-width="0.75" stroke-linecap="round"/>
</svg>
